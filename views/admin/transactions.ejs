    function updateSummaryCards() {
        const totalGross = filteredTransactions.reduce((sum, tx) => sum + Number(tx.gross_amount || 0), 0);
        const totalAgentFee = filteredTransactions.reduce((sum, tx) => sum + getAgentFeeAmount(tx), 0);
        const now = new Date();
        const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        const lastDay = new Date(today);
        lastDay.setDate(today.getDate() - 1);

        const lastDayGross = filteredTransactions
            .filter((tx) => isSameDay(tx.transaction_date, lastDay))
            .reduce((sum, tx) => sum + Number(tx.gross_amount || 0), 0);
        const thisWeekGross = filteredTransactions
            .filter((tx) => isDateInCurrentWeek(tx.transaction_date))
            .reduce((sum, tx) => sum + Number(tx.gross_amount || 0), 0);
        const thisMonthGross = filteredTransactions
            .filter((tx) => isDateInCurrentMonth(tx.transaction_date))
            .reduce((sum, tx) => sum + Number(tx.gross_amount || 0), 0);
        const thisYearGross = filteredTransactions
            .filter((tx) => isDateInCurrentYear(tx.transaction_date))
            .reduce((sum, tx) => sum + Number(tx.gross_amount || 0), 0);
        const clientMap = new Map();
        const agentMap = new Map();

        filteredTransactions.forEach((tx) => {
            const client = tx.client_name || 'N/A';
            const gross = Number(tx.gross_amount || 0);
            const agentFee = getAgentFeeAmount(tx);
            clientMap.set(client, Number(clientMap.get(client) || 0) + gross);

            const agentName = tx.agent_name || 'No Agent';
            const row = agentMap.get(agentName) || {
                name: agentName,
                totalAgentFee: 0,
                lastDay: 0,
                week: 0,
                month: 0,
                year: 0,
                transactions: 0
            };
            row.totalAgentFee += agentFee;
            row.transactions += 1;
            if (isSameDay(tx.transaction_date, lastDay)) row.lastDay += agentFee;
            if (isDateInCurrentWeek(tx.transaction_date)) row.week += agentFee;
            if (isDateInCurrentMonth(tx.transaction_date)) row.month += agentFee;
            if (isDateInCurrentYear(tx.transaction_date)) row.year += agentFee;
            agentMap.set(agentName, row);
        });
        const topClient = Array.from(clientMap.entries()).sort((a, b) => b[1] - a[1])[0];

        document.getElementById('summary-completed').textContent = formatCurrencySafe(totalGross);
        document.getElementById('summary-agent-fee').textContent = formatCurrencySafe(totalAgentFee);
        document.getElementById('summary-last-day').textContent = formatCurrencySafe(lastDayGross);
        document.getElementById('summary-this-week').textContent = formatCurrencySafe(thisWeekGross);
        document.getElementById('summary-this-month').textContent = formatCurrencySafe(thisMonthGross);
        document.getElementById('summary-this-year').textContent = formatCurrencySafe(thisYearGross);
        document.getElementById('summary-total-transactions').textContent = Number(filteredTransactions.length).toLocaleString('id-ID');
        document.getElementById('kpi-total-clients').textContent = Number(clientMap.size).toLocaleString('id-ID');
        document.getElementById('kpi-top-client').textContent = topClient?.[0] || '-';
        document.getElementById('kpi-top-client-revenue').textContent = formatCurrencySafe(topClient?.[1] || 0);
        renderAgentPerformance(agentMap);
    }

    function buildTrendChart() {
        const ctx = document.getElementById('transactionsTrendChart');
        if (!ctx) return;

        const map = new Map();
        filteredTransactions.forEach((tx) => {
            const d = new Date(tx.transaction_date);
            if (Number.isNaN(d.getTime())) return;
            const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
            map.set(key, Number(map.get(key) || 0) + Number(tx.gross_amount || 0));
        });

        const labels = Array.from(map.keys()).sort();
        const values = labels.map((k) => Number(map.get(k) || 0));

        if (transactionsTrendChart) {
            transactionsTrendChart.destroy();
        }

        transactionsTrendChart = new Chart(ctx.getContext('2d'), {
            type: 'line',
            data: {
                labels: labels.map((k) => {
                    const d = new Date(k + 'T00:00:00');
                    return d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
                }),
                datasets: [{
                    label: 'Revenue',
                    data: values,
                    borderColor: 'rgb(59, 130, 246)',
                    backgroundColor: 'rgba(59, 130, 246, 0.12)',
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: (v) => 'Rp ' + Number(v || 0).toLocaleString('id-ID')
                        }
                    }
                }
            }
        });
    }

