    async function viewTransaction(id) {
        const content = document.getElementById('transactionDetailContent');
        content.innerHTML = '<p class="text-gray-500">Loading detail...</p>';
        document.getElementById('transactionDetailModal').classList.remove('hidden');

        try {
            const response = await fetch(`/api/transactions/${id}`, { credentials: 'include' });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Gagal memuat detail transaksi');
            }

            const tx = data.data?.transaction || {};
            const model = data.data?.model || {};
            lastTransactionDetail = { tx, model };
            const grossAmount = Number(tx.gross_amount || 0);
            const adminFeeAmount = Number(tx.admin_fee || 0);
            const agentFeeAmount = Number(tx.agent_fee_total || Math.max(grossAmount - adminFeeAmount - Number(tx.net_amount || 0), 0));
            const netAmount = Number(tx.net_amount || 0);
            const rateAmount = Number(tx.model_rate || model.rate || tx.current_model_rate || 0);
            const gross = grossAmount.toLocaleString('id-ID');
            const adminFee = adminFeeAmount.toLocaleString('id-ID');
            const agentFee = agentFeeAmount.toLocaleString('id-ID');
            const net = netAmount.toLocaleString('id-ID');
