<!-- Transaction Detail Modal -->
<div id="transactionDetailModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-gray-800">Transaction Detail</h3>
            <button type="button" onclick="closeTransactionDetailModal()" class="text-gray-500 hover:text-gray-700"><i class="fas fa-times"></i></button>
        </div>
        <div id="transactionDetailContent" class="text-sm text-gray-700">Loading...</div>
    </div>
</div>

<!-- Edit Transaction Modal -->
<div id="transactionEditModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-gray-800">Edit Transaction</h3>
            <button type="button" onclick="closeEditTransactionModal()" class="text-gray-500 hover:text-gray-700"><i class="fas fa-times"></i></button>
        </div>
        <form id="editTransactionForm" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="hidden" id="editTransactionId">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Model</label>
                <input id="editModelName" type="text" class="w-full border rounded-lg px-3 py-2 bg-gray-50" readonly>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Client Name *</label>
                <input id="editClientName" type="text" class="w-full border rounded-lg px-3 py-2" required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Transaction Date *</label>
                <input id="editTransactionDate" type="date" class="w-full border rounded-lg px-3 py-2" required>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Transaction Count *</label>
                <input id="editTransactionCount" type="number" min="1" class="w-full border rounded-lg px-3 py-2" required>
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea id="editDescription" rows="3" class="w-full border rounded-lg px-3 py-2"></textarea>
            </div>
        </form>
        <div class="flex justify-end gap-2 mt-6">
            <button type="button" onclick="closeEditTransactionModal()" class="px-4 py-2 border rounded-lg">Cancel</button>
            <button type="button" onclick="submitEditTransaction()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save</button>
        </div>
    </div>
</div>

<script>
    const allTransactions = <%- JSON.stringify(typeof transactions !== 'undefined' ? transactions : []) %>;
    let filteredTransactions = [...allTransactions];
    let currentPage = 1;
    const pageSize = 10;
    let transactionsTrendChart = null;

    function formatCurrencySafe(n) {
        return 'Rp ' + Number(n || 0).toLocaleString('id-ID');
    }

    function formatDateSafe(value) {
        if (!value) return '-';
        const d = new Date(value);
        if (Number.isNaN(d.getTime())) return '-';
        return d.toLocaleDateString('id-ID');
    }

    function renderTransactionsTable() {
        const tbody = document.getElementById('transactions-table-body');
        const total = filteredTransactions.length;
        const totalPages = Math.max(Math.ceil(total / pageSize), 1);
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * pageSize;
        const pageItems = filteredTransactions.slice(start, start + pageSize);

        if (!pageItems.length) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                        <i class="fas fa-inbox text-4xl mb-2"></i>
                        <p>No transactions found</p>
                    </td>
                </tr>`;
        } else {
            tbody.innerHTML = pageItems.map((transaction) => `
                <tr class="hover:bg-gray-50 transition">
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">${formatDateSafe(transaction.transaction_date)}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">${transaction.model_name || '-'}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">Trx x ${Number(transaction.transaction_count || 0)}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">${transaction.client_name || 'N/A'}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">${formatCurrencySafe(transaction.gross_amount)}</td>
                    <td class="px-6 py-4 whitespace-nowrap"><span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">recorded</span></td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <button onclick="viewTransaction('${transaction.id}')" class="text-admin-600 hover:text-admin-900 mr-3" title="View"><i class="fas fa-eye"></i></button>
                        <button onclick="openEditTransaction('${transaction.id}')" class="text-emerald-600 hover:text-emerald-900 mr-3" title="Edit"><i class="fas fa-pen"></i></button>
                        <button onclick="deleteTransaction('${transaction.id}')" class="text-red-600 hover:text-red-900" title="Delete"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>`).join('');
        }

        document.getElementById('pagination-info').textContent = `Showing ${total === 0 ? 0 : start + 1}-${Math.min(start + pageItems.length, total)} of ${total}`;
        document.getElementById('current-page-label').textContent = `Page ${currentPage} / ${totalPages}`;
        document.getElementById('prev-page-btn').disabled = currentPage <= 1;
        document.getElementById('next-page-btn').disabled = currentPage >= totalPages;
        document.getElementById('tx-count-info').textContent = `${total} records`;
    }

    function buildTrendChart() {
        const ctx = document.getElementById('transactionsTrendChart');
        if (!ctx) return;

        const map = new Map();
        filteredTransactions.forEach((tx) => {
            const d = new Date(tx.transaction_date);
            if (Number.isNaN(d.getTime())) return;
            const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
            map.set(key, Number(map.get(key) || 0) + Number(tx.gross_amount || 0));
        });

        const labels = Array.from(map.keys()).sort();
        const values = labels.map((k) => Number(map.get(k) || 0));

        if (transactionsTrendChart) {
            transactionsTrendChart.destroy();
        }

        transactionsTrendChart = new Chart(ctx.getContext('2d'), {
            type: 'line',
            data: {
                labels: labels.map((k) => {
                    const d = new Date(k + 'T00:00:00');
                    return d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
                }),
                datasets: [{
                    label: 'Revenue',
                    data: values,
                    borderColor: 'rgb(59, 130, 246)',
                    backgroundColor: 'rgba(59, 130, 246, 0.12)',
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: (v) => 'Rp ' + Number(v || 0).toLocaleString('id-ID')
                        }
                    }
                }
            }
        });
    }

    function applyFilters() {
        const search = document.getElementById('search').value.toLowerCase();
        const status = document.getElementById('statusFilter').value.toLowerCase();
        const fromDate = document.getElementById('fromDate').value;
        const toDate = document.getElementById('toDate').value;

        filteredTransactions = allTransactions.filter((tx) => {
            const txDate = tx.transaction_date ? new Date(tx.transaction_date) : null;
            const matchSearch = !search || String(tx.model_name || '').toLowerCase().includes(search) || String(tx.client_name || '').toLowerCase().includes(search);
            const matchStatus = !status || status === 'recorded';
            const matchFrom = !fromDate || (txDate && txDate >= new Date(fromDate + 'T00:00:00'));
            const matchTo = !toDate || (txDate && txDate <= new Date(toDate + 'T23:59:59'));
            return matchSearch && matchStatus && matchFrom && matchTo;
        });

        currentPage = 1;
        renderTransactionsTable();
        buildTrendChart();
    }

    function filterTransactions() {
        applyFilters();
    }

    function clearFilters() {
        document.getElementById('search').value = '';
        document.getElementById('statusFilter').value = '';
        document.getElementById('fromDate').value = '';
        document.getElementById('toDate').value = '';
        applyFilters();
    }

    function changePage(delta) {
        const totalPages = Math.max(Math.ceil(filteredTransactions.length / pageSize), 1);
        currentPage = Math.min(Math.max(currentPage + delta, 1), totalPages);
        renderTransactionsTable();
    }
    
    function closeTransactionDetailModal() {
        document.getElementById('transactionDetailModal').classList.add('hidden');
    }

    function closeEditTransactionModal() {
        document.getElementById('transactionEditModal').classList.add('hidden');
    }

    async function viewTransaction(id) {
        const content = document.getElementById('transactionDetailContent');
        content.innerHTML = '<p class="text-gray-500">Loading detail...</p>';
        document.getElementById('transactionDetailModal').classList.remove('hidden');

        try {
            const response = await fetch(`/api/transactions/${id}`, { credentials: 'include' });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Gagal memuat detail transaksi');
            }

            const tx = data.data?.transaction || {};
            const model = data.data?.model || {};
            const gross = Number(tx.gross_amount || 0).toLocaleString('id-ID');
            const net = Number(tx.net_amount || 0).toLocaleString('id-ID');
            const fee = Number(tx.admin_fee || 0).toLocaleString('id-ID');
            content.innerHTML = `
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div><span class="font-semibold">Model:</span> ${model.full_name || tx.model_name || '-'}</div>
                    <div><span class="font-semibold">Client:</span> ${tx.client_name || '-'}</div>
                    <div><span class="font-semibold">Date:</span> ${formatDateSafe(tx.transaction_date)}</div>
                    <div><span class="font-semibold">TRX Count:</span> ${tx.transaction_count || 0}</div>
                    <div><span class="font-semibold">Gross:</span> Rp ${gross}</div>
                    <div><span class="font-semibold">Admin Fee:</span> Rp ${fee}</div>
                    <div><span class="font-semibold">Net:</span> Rp ${net}</div>
                    <div><span class="font-semibold">Created By:</span> ${tx.created_by_email || '-'}</div>
                    <div class="md:col-span-2"><span class="font-semibold">Description:</span> ${tx.notes || '-'}</div>
                </div>
            `;
        } catch (error) {
            content.innerHTML = `<p class="text-red-600">${error.message || 'Terjadi kesalahan'}</p>`;
        }
    }

    async function openEditTransaction(id) {
        try {
            const response = await fetch(`/api/transactions/${id}`, { credentials: 'include' });
            const data = await response.json();
            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Gagal memuat data transaksi');
            }

            const tx = data.data?.transaction || {};
            const model = data.data?.model || {};
            document.getElementById('editTransactionId').value = tx.id || id;
            document.getElementById('editModelName').value = model.full_name || tx.model_name || '-';
            document.getElementById('editClientName').value = tx.client_name || '';
            document.getElementById('editTransactionDate').value = tx.transaction_date ? new Date(tx.transaction_date).toISOString().slice(0, 10) : '';
            document.getElementById('editTransactionCount').value = tx.transaction_count || 1;
            document.getElementById('editDescription').value = tx.notes || '';

            document.getElementById('transactionEditModal').classList.remove('hidden');
        } catch (error) {
            showToast(error.message || 'Terjadi kesalahan', 'error');
        }
    }

    async function submitEditTransaction() {
        const id = document.getElementById('editTransactionId').value;
        const payload = {
            client_name: document.getElementById('editClientName').value.trim(),
            transaction_date: document.getElementById('editTransactionDate').value,
            transaction_count: Number(document.getElementById('editTransactionCount').value || 0),
            description: document.getElementById('editDescription').value.trim()
        };

        if (!payload.client_name || !payload.transaction_date || payload.transaction_count < 1) {
            showToast('Client, tanggal, dan jumlah trx wajib diisi', 'error');
            return;
        }

        try {
            const response = await fetch(`/api/transactions/${id}`, {
                method: 'PUT',
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await response.json();

            if (!response.ok || !data.success) {
                const msg = data.message || (Array.isArray(data.errors) && data.errors[0]?.msg) || 'Gagal update transaksi';
                throw new Error(msg);
            }

            closeEditTransactionModal();
            showToast('Transaction berhasil diupdate', 'success');
            setTimeout(() => window.location.reload(), 700);
        } catch (error) {
            showToast(error.message || 'Terjadi kesalahan', 'error');
        }
    }
    
    async function deleteTransaction(id) {
        if (!confirm('Are you sure you want to delete this transaction?')) return;
        
        try {
            showLoading();
            const response = await fetch(`/api/transactions/${id}`, {
                method: 'DELETE',
                credentials: 'include'
            });
            
            const data = await response.json();
            hideLoading();
            
            if (data.success) {
                showToast('Transaction deleted', 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                showToast(data.message || 'Failed to delete', 'error');
            }
        } catch (error) {
            hideLoading();
            showToast('An error occurred', 'error');
        }
    }
    
    function exportTransactions() {
        showLoading();
        window.location.href = '/admin/transactions/export';
        setTimeout(hideLoading, 2000);
    }

    async function loadClientKpis() {
        try {
            const response = await fetch('/api/transactions/client-kpis', { credentials: 'include' });
            const data = await response.json();
            if (!response.ok || !data.success) return;

            document.getElementById('kpi-total-clients').textContent = Number(data.data?.total_clients || 0).toLocaleString('id-ID');
            const topClient = data.data?.top_client;
            document.getElementById('kpi-top-client').textContent = topClient?.client_name || '-';
            document.getElementById('kpi-top-client-revenue').textContent = 'Rp ' + Number(topClient?.total_revenue || 0).toLocaleString('id-ID');
        } catch (_) {}
    }

    document.addEventListener('DOMContentLoaded', () => {
        loadClientKpis();
        applyFilters();
    });
</script>
            </main>
        </div>
    </div>
    
    <!-- Sidebar Toggle Script -->
    <script>
        const sidebar = document.getElementById('sidebar');
        const openBtn = document.getElementById('open-sidebar');
        const closeBtn = document.getElementById('close-sidebar');
        
        openBtn?.addEventListener('click', () => {
            sidebar.classList.remove('-translate-x-full');
        });
        
        closeBtn?.addEventListener('click', () => {
            sidebar.classList.add('-translate-x-full');
        });
        
        // Close sidebar when clicking outside on mobile
        document.addEventListener('click', (e) => {
            if (window.innerWidth < 768 && 
                !sidebar.contains(e.target) && 
                !openBtn.contains(e.target) &&
                !sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.add('-translate-x-full');
            }
        });
    </script>
    
    <%- include('../partials/footer') %>
</body>
</html>
