            <!-- Page Content -->
            <main class="flex-1 overflow-y-auto p-6">
<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center space-y-4 md:space-y-0">
        <div>
            <h2 class="text-2xl font-bold text-gray-800">Transaction History</h2>
            <p class="text-gray-600 text-sm mt-1">View and manage all transactions</p>
        </div>

        <div class="flex space-x-3">
            <a href="/admin/transactions/new"
               class="bg-admin-600 text-white px-4 py-2 rounded-lg hover:bg-admin-700 transition">
                <i class="fas fa-plus mr-2"></i>Add Transaction
            </a>
            <button onclick="exportClientInvoice()"
                    class="bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700 transition">
                <i class="fas fa-file-invoice mr-2"></i>Invoice Client
            </button>
            <button onclick="exportTransactions()"
                    class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition">
                <i class="fas fa-file-export mr-2"></i>Export
            </button>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-md p-6">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Model</label>
                <select id="modelFilter"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-admin-500"
                        onchange="filterTransactions()">
                    <option value="">All Models</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
                <select id="statusFilter"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-admin-500"
                        onchange="filterTransactions()">
                    <option value="">All Status</option>
                    <option value="recorded">Recorded</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">From Date</label>
                <input type="date"
                       id="fromDate"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-admin-500"
                       onchange="filterTransactions()">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">To Date</label>
                <input type="date"
                       id="toDate"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-admin-500"
                       onchange="filterTransactions()">
            </div>

            <div class="flex items-end">
                <button onclick="clearFilters()"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition text-sm">
                    <i class="fas fa-times mr-2"></i>Clear
                </button>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500">
            <p class="text-gray-500 text-sm font-medium">Total Revenue</p>
            <p id="summary-completed" class="text-3xl font-bold text-gray-800 mt-2">Rp 0</p>
        </div>

        <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-red-500">
            <p class="text-gray-500 text-sm font-medium">Total Agent Fee</p>
            <p id="summary-agent-fee" class="text-3xl font-bold text-gray-800 mt-2">Rp 0</p>
        </div>

        <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-slate-500">
            <p class="text-gray-500 text-sm font-medium">Last Day</p>
            <p id="summary-last-day" class="text-3xl font-bold text-gray-800 mt-2">Rp 0</p>
        </div>

        <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-yellow-500">
            <p class="text-gray-500 text-sm font-medium">This Week</p>
            <p id="summary-this-week" class="text-3xl font-bold text-gray-800 mt-2">Rp 0</p>
        </div>

        <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-admin-500">
            <p class="text-gray-500 text-sm font-medium">This Month</p>
            <p id="summary-this-month" class="text-3xl font-bold text-gray-800 mt-2">Rp 0</p>
        </div>

        <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-cyan-500">
            <p class="text-gray-500 text-sm font-medium">This Year</p>
            <p id="summary-this-year" class="text-3xl font-bold text-gray-800 mt-2">Rp 0</p>
        </div>

        <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-purple-500">
            <p class="text-gray-500 text-sm font-medium">Total Transactions</p>
            <p id="summary-total-transactions" class="text-3xl font-bold text-gray-800 mt-2">0</p>
        </div>

        <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-indigo-500">
            <p class="text-gray-500 text-sm font-medium">Total Clients</p>
            <p id="kpi-total-clients" class="text-3xl font-bold text-gray-800 mt-2">0</p>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-pink-500">
            <p class="text-gray-500 text-sm font-medium">Top Client (Revenue)</p>
            <p id="kpi-top-client" class="text-lg font-bold text-gray-800 mt-2">-</p>
            <p id="kpi-top-client-revenue" class="text-sm text-gray-500 mt-1">Rp 0</p>
        </div>
        <div class="xl:col-span-2 bg-white rounded-xl shadow-md overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between gap-4">
                <div>
                    <h3 class="text-lg font-bold text-gray-800">Agent Fee Performance</h3>
                    <p class="text-sm text-gray-500">Breakdown per agent from current filters</p>
                </div>
                <div class="flex items-center gap-2">
                    <button type="button" onclick="viewAgentFeeBreakdown()" class="px-3 py-2 rounded-lg border border-admin-200 text-admin-700 hover:bg-admin-50 text-sm font-semibold">
                        <i class="fas fa-eye mr-1"></i>View Breakdown
                    </button>
                    <button type="button" onclick="exportAgentFeeBreakdownPdf()" class="px-3 py-2 rounded-lg bg-gray-900 text-white hover:bg-gray-800 text-sm font-semibold">
                        <i class="fas fa-file-pdf mr-1"></i>Export PDF
                    </button>
                    <i class="fas fa-user-tie text-admin-500 text-xl ml-1"></i>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 text-sm">
                    <thead class="bg-gray-50 text-xs uppercase text-gray-500">
                        <tr>
                            <th class="px-6 py-3 text-left">Agent</th>
                            <th class="px-6 py-3 text-right">Total Agent Fee</th>
                            <th class="px-6 py-3 text-right">Last Day</th>
                            <th class="px-6 py-3 text-right">Week</th>
                            <th class="px-6 py-3 text-right">Month</th>
                            <th class="px-6 py-3 text-right">Year</th>
                            <th class="px-6 py-3 text-right">TRX</th>
                        </tr>
                    </thead>
                    <tbody id="agent-performance-body" class="divide-y divide-gray-100"></tbody>
                </table>
            </div>
        </div>
    </div>


    <div class="bg-white rounded-xl shadow-md p-6">
        <div class="flex items-center justify-between mb-3">
            <h3 class="text-lg font-bold text-gray-800">Revenue Trend (Transactions)</h3>
            <span id="tx-count-info" class="text-sm text-gray-500">0 records</span>
        </div>
        <div class="h-64">
            <canvas id="transactionsTrendChart"></canvas>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-admin-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Model</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Job Type</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Client</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody id="transactions-table-body" class="bg-white divide-y divide-gray-200"></tbody>
            </table>
        </div>
        <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between">
            <p id="pagination-info" class="text-sm text-gray-500">Showing 0 of 0</p>
            <div class="flex items-center gap-2">
                <button id="prev-page-btn" onclick="changePage(-1)" class="px-3 py-1 border rounded disabled:opacity-50" disabled>Previous</button>
                <span id="current-page-label" class="text-sm text-gray-600">Page 1</span>
                <button id="next-page-btn" onclick="changePage(1)" class="px-3 py-1 border rounded disabled:opacity-50" disabled>Next</button>
            </div>
        </div>
    </div>
</div>



<!-- Agent Fee Breakdown Modal -->
<div id="agentFeeBreakdownModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-6xl max-h-[90vh] overflow-hidden flex flex-col">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <div>
                <h3 class="text-xl font-bold text-gray-800">Agent Fee Breakdown</h3>
                <p class="text-sm text-gray-500">Detailed agent fee transactions from current filters</p>
            </div>
            <button type="button" onclick="closeAgentFeeBreakdownModal()" class="text-gray-500 hover:text-gray-700"><i class="fas fa-times"></i></button>
        </div>
        <div id="agentFeeBreakdownContent" class="overflow-auto p-6 text-sm text-gray-700">Loading...</div>
        <div class="flex justify-end gap-2 px-6 py-4 border-t border-gray-100 bg-gray-50">
            <button type="button" onclick="closeAgentFeeBreakdownModal()" class="px-4 py-2 border rounded-lg bg-white">Close</button>
            <button type="button" onclick="exportAgentFeeBreakdownPdf()" class="px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800"><i class="fas fa-file-pdf mr-2"></i>Export PDF</button>
        </div>
    </div>
</div>

<!-- Transaction Detail Modal -->
<div id="transactionDetailModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-gray-800">Transaction Detail</h3>
            <button type="button" onclick="closeTransactionDetailModal()" class="text-gray-500 hover:text-gray-700"><i class="fas fa-times"></i></button>
        </div>
        <div id="transactionDetailContent" class="text-sm text-gray-700">Loading...</div>
    </div>
</div>

<!-- Edit Transaction Modal -->
<div id="transactionEditModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-gray-800">Edit Transaction</h3>
            <button type="button" onclick="closeEditTransactionModal()" class="text-gray-500 hover:text-gray-700"><i class="fas fa-times"></i></button>
        </div>
        <form id="editTransactionForm" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="hidden" id="editTransactionId">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Model</label>
                <input id="editModelName" type="text" class="w-full border rounded-lg px-3 py-2 bg-gray-50" readonly>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Admin Fee</label>
                <input id="editAdminFee" type="number" min="0" class="w-full border rounded-lg px-3 py-2" value="0">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Admin Fee</label>
                <input id="editAdminFee" type="number" min="0" class="w-full border rounded-lg px-3 py-2" value="0">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Admin Fee</label>
                <input id="editAdminFee" type="number" min="0" class="w-full border rounded-lg px-3 py-2" value="0">
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea id="editDescription" rows="3" class="w-full border rounded-lg px-3 py-2"></textarea>
            </div>
        </form>
        <div class="flex justify-end gap-2 mt-6">
            <button type="button" onclick="closeEditTransactionModal()" class="px-4 py-2 border rounded-lg">Cancel</button>
            <button type="button" onclick="submitEditTransaction()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Save</button>
        </div>
    </div>
</div>

<script>
    const allTransactions = <%- JSON.stringify(typeof transactions !== 'undefined' ? transactions : []) %>;
    let filteredTransactions = [...allTransactions];
    let currentPage = 1;
    const pageSize = 10;
    let transactionsTrendChart = null;
    let lastTransactionDetail = null;

    function formatCurrencySafe(n) {
        return 'Rp ' + Number(n || 0).toLocaleString('id-ID');
    }

    function formatDateSafe(value) {
        if (!value) return '-';
        const d = new Date(value);
        if (Number.isNaN(d.getTime())) return '-';
        return d.toLocaleDateString('id-ID');
    }

    function renderTransactionsTable() {
        const tbody = document.getElementById('transactions-table-body');
        const total = filteredTransactions.length;
        const totalPages = Math.max(Math.ceil(total / pageSize), 1);
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * pageSize;
        const pageItems = filteredTransactions.slice(start, start + pageSize);

        if (!pageItems.length) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                        <i class="fas fa-inbox text-4xl mb-2"></i>
                        <p>No transactions found</p>
                    </td>
                </tr>`;
        } else {
            tbody.innerHTML = pageItems.map((transaction) => `
                <tr class="hover:bg-gray-50 transition">
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">${formatDateSafe(transaction.transaction_date)}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                        ${transaction.model_name || '-'}
                        <div class="text-xs text-gray-500">${transaction.model_grade_name || 'No grade'}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">Trx x ${Number(transaction.transaction_count || 0)}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">${transaction.client_name || 'N/A'}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">${formatCurrencySafe(transaction.gross_amount)}</td>
                    <td class="px-6 py-4 whitespace-nowrap"><span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">recorded</span></td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <button onclick="viewTransaction('${transaction.id}')" class="text-admin-600 hover:text-admin-900 mr-3" title="View"><i class="fas fa-eye"></i></button>
                        <button onclick="openEditTransaction('${transaction.id}')" class="text-emerald-600 hover:text-emerald-900 mr-3" title="Edit"><i class="fas fa-pen"></i></button>
                        <button onclick="deleteTransaction('${transaction.id}')" class="text-red-600 hover:text-red-900" title="Delete"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>`).join('');
        }

        document.getElementById('pagination-info').textContent = `Showing ${total === 0 ? 0 : start + 1}-${Math.min(start + pageItems.length, total)} of ${total}`;
        document.getElementById('current-page-label').textContent = `Page ${currentPage} / ${totalPages}`;
        document.getElementById('prev-page-btn').disabled = currentPage <= 1;
        document.getElementById('next-page-btn').disabled = currentPage >= totalPages;
        document.getElementById('tx-count-info').textContent = `${total} records`;
    }


    function getTransactionDate(value) {
        const date = value ? new Date(value) : null;
        return date && !Number.isNaN(date.getTime()) ? date : null;
    }

    function getAgentFeeAmount(tx) {
        const storedAgentFee = Number(tx.agent_fee_total || 0);
        if (storedAgentFee > 0) return storedAgentFee;
        const gross = Number(tx.gross_amount || 0);
        const adminFee = Number(tx.admin_fee || 0);
        const net = Number(tx.net_amount || 0);
        return Math.max(gross - adminFee - net, 0);
    }

    function isSameDay(value, referenceDate) {
        const date = getTransactionDate(value);
        return Boolean(date)
            && date.getFullYear() === referenceDate.getFullYear()
            && date.getMonth() === referenceDate.getMonth()
            && date.getDate() === referenceDate.getDate();
    }

    function isDateInCurrentWeek(value) {
        const date = getTransactionDate(value);
        if (!date) return false;
        const now = new Date();
        const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        const weekStart = new Date(today);
        weekStart.setDate(today.getDate() - today.getDay());
        const weekEnd = new Date(weekStart);
        weekEnd.setDate(weekStart.getDate() + 6);
        weekEnd.setHours(23, 59, 59, 999);
        return date >= weekStart && date <= weekEnd;
    }

    function isDateInCurrentMonth(value) {
        const date = getTransactionDate(value);
        const now = new Date();
        return Boolean(date) && date.getFullYear() === now.getFullYear() && date.getMonth() === now.getMonth();
    }

    function isDateInCurrentYear(value) {
        const date = getTransactionDate(value);
        return Boolean(date) && date.getFullYear() === new Date().getFullYear();
    }

