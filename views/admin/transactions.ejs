    async function openEditTransaction(id) {
        try {
            const response = await fetch(`/api/transactions/${id}`, { credentials: 'include' });
            const data = await response.json();
            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Gagal memuat data transaksi');
            }

            const tx = data.data?.transaction || {};
            const model = data.data?.model || {};
            document.getElementById('editTransactionId').value = tx.id || id;
            document.getElementById('editModelName').value = model.full_name || tx.model_name || '-';
            document.getElementById('editClientName').value = tx.client_name || '';
            document.getElementById('editTransactionDate').value = tx.transaction_date ? new Date(tx.transaction_date).toISOString().slice(0, 10) : '';
            document.getElementById('editTransactionCount').value = tx.transaction_count || 1;
            document.getElementById('editAdminFee').value = Number(tx.admin_fee || 0);
            document.getElementById('editDescription').value = tx.notes || '';

            document.getElementById('transactionEditModal').classList.remove('hidden');
        } catch (error) {
            showToast(error.message || 'Terjadi kesalahan', 'error');
        }
    }

    async function submitEditTransaction() {
        const id = document.getElementById('editTransactionId').value;
        const payload = {
            client_name: document.getElementById('editClientName').value.trim(),
            transaction_date: document.getElementById('editTransactionDate').value,
            transaction_count: Number(document.getElementById('editTransactionCount').value || 0),
            admin_fee: Number(document.getElementById('editAdminFee').value || 0),
            description: document.getElementById('editDescription').value.trim()
        };

        if (!payload.client_name || !payload.transaction_date || payload.transaction_count < 1) {
            showToast('Client, tanggal, dan jumlah trx wajib diisi', 'error');
            return;
        }

        try {
            const response = await fetch(`/api/transactions/${id}`, {
                method: 'PUT',
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await response.json();

            if (!response.ok || !data.success) {
                const msg = data.message || (Array.isArray(data.errors) && data.errors[0]?.msg) || 'Gagal update transaksi';
                throw new Error(msg);
            }

            closeEditTransactionModal();
            showToast('Transaction berhasil diupdate', 'success');
            setTimeout(() => window.location.reload(), 700);
        } catch (error) {
            showToast(error.message || 'Terjadi kesalahan', 'error');
        }
    }

    async function deleteTransaction(id) {
        if (!confirm('Are you sure you want to delete this transaction?')) return;

        try {
            showLoading();
            const response = await fetch(`/api/transactions/${id}`, {
                method: 'DELETE',
                credentials: 'include'
            });

            const data = await response.json();
            hideLoading();

            if (data.success) {
                showToast('Transaction deleted', 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                showToast(data.message || 'Failed to delete', 'error');
            }
        } catch (error) {
            hideLoading();
            showToast('An error occurred', 'error');
        }
    }


