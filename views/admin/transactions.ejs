                        <i class="fas fa-tachometer-alt w-5"></i>
                        <span>Dashboard</span>
                    </a>

                    <a href="/admin/models" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-users w-5"></i>
                        <span>Models</span>
                    </a>
                    <a href="/admin/model-grades" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-layer-group w-5"></i>
