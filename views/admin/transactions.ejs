    <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-gray-800">Edit Transaction</h3>
            <button type="button" onclick="closeEditTransactionModal()" class="text-gray-500 hover:text-gray-700"><i class="fas fa-times"></i></button>
        </div>
        <form id="editTransactionForm" class="grid grid-cols-1 md:grid-cols-2 gap-4">
