            const gross = Number(tx.gross_amount || 0);
            const adminFee = Number(tx.admin_fee || 0);
            const net = Number(tx.net_amount || 0);
            const agentFee = getAgentFeeAmount(tx);
            const row = agentMap.get(agentName) || {
                name: agentName,
                totalGross: 0,
                totalAdminFee: 0,
                totalAgentFee: 0,
                totalNet: 0,
                transactionRows: []
            };

            row.totalGross += gross;
            row.totalAdminFee += adminFee;
            row.totalAgentFee += agentFee;
            row.totalNet += net;
            row.transactionRows.push({
                date: tx.transaction_date,
                model: tx.model_name || '-',
                grade: tx.model_grade_name || '-',
                client: tx.client_name || '-',
                trx: Number(tx.transaction_count || 0),
                gross,
                adminFee,
                agentFee,
                net
            });
            agentMap.set(agentName, row);
        });

        return Array.from(agentMap.values()).sort((a, b) => b.totalAgentFee - a.totalAgentFee);
