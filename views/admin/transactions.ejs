    function applyFilters() {
        const selectedModel = document.getElementById('modelFilter').value.toLowerCase();
        const status = document.getElementById('statusFilter').value.toLowerCase();
        const fromDate = document.getElementById('fromDate').value;
        const toDate = document.getElementById('toDate').value;

        filteredTransactions = allTransactions.filter((tx) => {
            const txDate = tx.transaction_date ? new Date(tx.transaction_date) : null;
            const matchSearch = !selectedModel || String(tx.model_name || '').toLowerCase() === selectedModel;
            const matchStatus = !status || status === 'recorded';
            const matchFrom = !fromDate || (txDate && txDate >= new Date(fromDate + 'T00:00:00'));
            const matchTo = !toDate || (txDate && txDate <= new Date(toDate + 'T23:59:59'));
            return matchSearch && matchStatus && matchFrom && matchTo;
        });

        currentPage = 1;
        renderTransactionsTable();
        updateSummaryCards();
        buildTrendChart();
    }

    function filterTransactions() {
        applyFilters();
    }

    function clearFilters() {
        document.getElementById('modelFilter').value = '';
        document.getElementById('statusFilter').value = '';
        document.getElementById('fromDate').value = '';
        document.getElementById('toDate').value = '';
        applyFilters();
    }

