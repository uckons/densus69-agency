<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Transaction - SkyLin Agency</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⭐</text></svg>">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        admin: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-50">
    <%- include('../partials/header') %>
    
    <div class="flex h-screen bg-gray-100">
        <!-- Sidebar -->
        <aside id="sidebar" class="sidebar fixed md:relative inset-y-0 left-0 z-30 w-64 bg-admin-800 text-white transform -translate-x-full md:translate-x-0 transition-transform duration-300">
            <div class="flex flex-col h-full">
                <!-- Logo -->
                <div class="flex items-center justify-between h-16 px-6 bg-admin-900">
                    <div class="flex items-center space-x-2">
                        <i class="fas fa-star text-admin-400 text-xl"></i>
                        <span class="text-xl font-bold">Admin Panel</span>
                    </div>
                    <button id="close-sidebar" class="md:hidden text-white hover:text-admin-300">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                
                <!-- Navigation -->
                <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
                    <a href="/admin/dashboard" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-tachometer-alt w-5"></i>
                        <span>Dashboard</span>
                    </a>
                    
                    <a href="/admin/models" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-users w-5"></i>
                        <span>Models</span>
                    </a>
                    <a href="/admin/model-grades" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-layer-group w-5"></i>
                        <span>Model Grades</span>
                    </a>
                    
                    
                    <a href="/admin/agents" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-user-tie w-5"></i>
                        <span>Agents</span>
                    </a>
                    
                    <a href="/admin/jobs" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-briefcase w-5"></i>
                        <span>Jobs</span>
                    </a>
                    
                    <a href="/admin/transactions" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition bg-admin-700">
                        <i class="fas fa-exchange-alt w-5"></i>
                        <span>Transactions</span>
                    </a>
                    
                    <a href="/admin/analytics" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-chart-line w-5"></i>
                        <span>Analytics</span>
                    </a>
                    
                    <a href="/admin/complaints" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-exclamation-triangle w-5"></i>
                        <span>Complaints</span>
                    </a>
                    
                    <hr class="my-4 border-admin-700">
                    
                    <a href="/admin/users" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-user-cog w-5"></i>
                        <span>Users</span>
                    </a>
                    
                    <hr class="my-4 border-admin-700">
                    
                    <a href="/" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-admin-700 transition">
                        <i class="fas fa-home w-5"></i>
                        <span>Public Site</span>
                    </a>
                    
                    <a href="/auth/logout" class="flex items-center space-x-3 px-4 py-3 rounded-lg hover:bg-red-600 transition text-red-300">
                        <i class="fas fa-sign-out-alt w-5"></i>
                        <span>Logout</span>
                    </a>
                </nav>
                
                <!-- User Info -->
                <div class="px-6 py-4 bg-admin-900 border-t border-admin-700">
                    <div class="flex items-center space-x-3">
                        <img src="/images/default-avatar.png" 
                             alt="Admin" 
                             class="w-10 h-10 rounded-full object-cover border-2 border-admin-600">
                        <div>
                            <p class="font-medium"><%= typeof user !== 'undefined' ? user.email : 'Admin' %></p>
                            <p class="text-xs text-admin-300">Administrator</p>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
        
        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Top Bar -->
            <header class="bg-white shadow-sm h-16 flex items-center justify-between px-6">
                <button id="open-sidebar" class="md:hidden text-gray-600 hover:text-gray-900">
                    <i class="fas fa-bars text-2xl"></i>
                </button>
                
                <h1 class="text-xl font-semibold text-gray-800">Add Transaction</h1>
                
                <div class="flex items-center space-x-4">
                    <a href="/auth/logout" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg transition">
                        <i class="fas fa-sign-out-alt mr-2"></i>Logout
                    </a>
                </div>
            </header>
            
            <!-- Page Content -->
            <main class="flex-1 overflow-y-auto p-6">
<div class="max-w-4xl mx-auto space-y-6">
    <!-- Header -->
    <div>
        <a href="/admin/transactions" class="text-admin-600 hover:text-admin-700 text-sm font-medium mb-2 inline-block">
            <i class="fas fa-arrow-left mr-2"></i>Back to Transactions
        </a>
        <h2 class="text-2xl font-bold text-gray-800">Add New Transaction</h2>
        <p class="text-gray-600 text-sm mt-1">Record a new transaction for a model</p>
    </div>
    
    <!-- Transaction Form -->
    <div class="bg-white rounded-xl shadow-md p-8">
        <form id="transaction-form" onsubmit="handleSubmit(event)">
            <div class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-user mr-2"></i>Assigned Model *
                        </label>
                        <div class="flex gap-2">
                            <select id="model_id" name="model_id" required
                                    class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-admin-500"
                                    onchange="updateModelRate(this)" onfocus="loadAssignedModels()">
                                <option value="">Choose assigned model...</option>
                            </select>
                            <button type="button" onclick="loadAssignedModels()" class="px-3 py-3 border border-gray-300 rounded-lg hover:bg-gray-50" title="Reload assigned models">
                                <i class="fas fa-rotate"></i>
                            </button>
                        </div>
                        <p id="model-assignment-info" class="text-xs text-gray-500 mt-1">Hanya model yang sedang di-assign pada job aktif.</p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-money-bill-wave mr-2"></i>Rate / Trx
                        </label>
                        <input type="text" id="model_rate_display" readonly
                               class="w-full px-4 py-3 border border-gray-200 bg-gray-50 rounded-lg"
                               value="Rp 0">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-calendar mr-2"></i>Transaction Date *
                        </label>
                        <input type="date" name="transaction_date" required
                               value="<%= new Date().toISOString().split('T')[0] %>"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-admin-500">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-layer-group mr-2"></i>Qty Trx (per hari) *
                        </label>
                        <input type="number" id="transaction_count" name="transaction_count" required min="1" value="1"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-admin-500"
                               oninput="calculateRevenue()">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-calculator mr-2"></i>Model Revenue
                        </label>
                        <input type="text" id="gross_amount_display" readonly
                               class="w-full px-4 py-3 border border-gray-200 bg-gray-50 rounded-lg"
                               value="Rp 0">
                        <p class="text-xs text-gray-500 mt-1">Formula: qty trx × rate</p>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="fas fa-building mr-2"></i>Client Name *
                    </label>
                    <input type="text" id="client_name" name="client_name" required
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-admin-500"
                           placeholder="Client atau brand">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="fas fa-align-left mr-2"></i>Description
                    </label>
                    <textarea name="description" rows="4"
                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-admin-500"
                              placeholder="Catatan tambahan"></textarea>
                </div>
            </div>

            <div class="flex justify-end space-x-4 mt-8 pt-6 border-t border-gray-200">
                <a href="/admin/transactions"
                   class="px-6 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition">
                    Cancel
                </a>
                <button type="submit"
                        class="px-6 py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition focus:outline-none focus:ring-2 focus:ring-blue-400">
                    <i class="fas fa-save mr-2"></i>Save Transaction
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    let assignedModels = [];

    const formatCurrencySafe = (n) => 'Rp ' + Number(n || 0).toLocaleString('id-ID');

    async function loadAssignedModels() {
        const select = document.getElementById('model_id');
        const assignmentInfo = document.getElementById('model-assignment-info');
        const previousSelection = select.value;

        select.innerHTML = '<option value="">Choose assigned model...</option>';

        try {
            const response = await fetch('/api/transactions/assigned-models', { credentials: 'include' });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.message || 'Gagal load assigned models');
            }

            assignedModels = data.data || [];

            if (!assignedModels.length) {
                assignmentInfo.textContent = 'Belum ada model yang di-assign ke job aktif.';
                updateModelRate(select);
                return;
            }

            assignmentInfo.textContent = `Assigned models loaded: ${assignedModels.length}`;

            assignedModels.forEach((item) => {
                const option = document.createElement('option');
                option.value = item.id;
                option.setAttribute('data-rate', item.rate || 0);
                option.setAttribute('data-client', item.client_name || '');
                option.textContent = `${item.full_name} - ${item.job_title || '-'} (${item.client_name || '-'})`;
                select.appendChild(option);
            });

            if (previousSelection && Array.from(select.options).some(opt => opt.value === previousSelection)) {
                select.value = previousSelection;
            }

            updateModelRate(select);
        } catch (error) {
            assignmentInfo.textContent = 'Gagal memuat assigned models.';
        }
    }

    function updateModelRate(select) {
        const selectedOption = select.options[select.selectedIndex];
        const rate = Number(selectedOption?.getAttribute('data-rate') || 0);
        const clientName = selectedOption?.getAttribute('data-client') || '';
        document.getElementById('model_rate_display').value = formatCurrencySafe(rate);

        const clientInput = document.getElementById('client_name');
        if (clientInput && clientName) {
            clientInput.value = clientName;
        }

        calculateRevenue();
    }

    function calculateRevenue() {
        const select = document.getElementById('model_id');
        const selectedOption = select.options[select.selectedIndex];
        const rate = Number(selectedOption?.getAttribute('data-rate') || 0);
        const qty = Number(document.getElementById('transaction_count').value || 0);
        const gross = qty * rate;

        document.getElementById('gross_amount_display').value = formatCurrencySafe(gross);
    }

    async function handleSubmit(event) {
        event.preventDefault();

        const form = event.target;
        const payload = {
            model_id: form.model_id.value,
            client_name: form.client_name.value,
            transaction_count: form.transaction_count.value,
            transaction_date: form.transaction_date.value,
            description: form.description.value
        };

        try {
            showLoading();
            const response = await fetch('/api/transactions', {
                method: 'POST',
                credentials: 'include',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const data = await response.json();
            hideLoading();

            if (response.ok && data.success) {
                showToast('Transaction created successfully', 'success');
                setTimeout(() => {
                    window.location.href = '/admin/transactions';
                }, 1000);
            } else {
                showToast(data.message || data.errors?.[0]?.msg || 'Failed to create transaction', 'error');
            }
        } catch (error) {
            hideLoading();
            showToast('An error occurred', 'error');
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        loadAssignedModels();
        calculateRevenue();

        setInterval(() => {
            if (document.visibilityState === 'visible') {
                loadAssignedModels();
            }
        }, 15000);
    });
</script>
            </main>
        </div>
    </div>
    
    <!-- Sidebar Toggle Script -->
    <script>
        const sidebar = document.getElementById('sidebar');
        const openBtn = document.getElementById('open-sidebar');
        const closeBtn = document.getElementById('close-sidebar');
        
        openBtn?.addEventListener('click', () => {
            sidebar.classList.remove('-translate-x-full');
        });
        
        closeBtn?.addEventListener('click', () => {
            sidebar.classList.add('-translate-x-full');
        });
        
        // Close sidebar when clicking outside on mobile
        document.addEventListener('click', (e) => {
            if (window.innerWidth < 768 && 
                !sidebar.contains(e.target) && 
                !openBtn.contains(e.target) &&
                !sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.add('-translate-x-full');
            }
        });
    </script>
    
    <%- include('../partials/footer') %>
</body>
</html>
